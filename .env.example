# ── Evolution API ──────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# ── Replicate (geração de imagens com IA) ──────────────────
# Crie sua conta em https://replicate.com e gere um token em:
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PIX ────────────────────────────────────────────────────
# Chave PIX que aparecerá nas mensagens ao cliente
MINHA_CHAVE_PIX=seuemail@email.com

# ── Números do operador / dono ─────────────────────────────
# Número que receberá os comprovantes e enviará LIBERAR
# Formato: DDI + DDD + número (sem +, traços ou espaços)
OPERATOR_PHONE=5511999999999

# Notificação extra (segundo número, opcional)
OWNER_PHONE=5511999999999
OWNER_PHONE_2=

# ── Imagens de prova social (links públicos) ───────────────
# Substitua pelas URLs reais de exemplos de ensaio
PROOF_IMAGE_1=https://picsum.photos/seed/mae1/800/1067
PROOF_IMAGE_2=https://picsum.photos/seed/mae2/800/1067

# ── Dados (pasta onde imagens geradas ficam salvas) ────────
# Em Railway: monte um Volume apontando para /app/data
DATA_DIR=./data

# ── Servidor ───────────────────────────────────────────────
PORT=3000
